#!/bin/bash

# Use the full path or ensure the binary is reachable
CMD="./target/release/binwalk $@"

# If no RUST_LOG level is defined, default to `info`
if [[ -z "${RUST_LOG}" ]]; then
    export RUST_LOG=info
fi

# Kill existing session if it exists (for clean testing)
tmux kill-session -t binwalk_split 2>/dev/null

# Create session and window
tmux new-session -d -s binwalk_split -n "Main"

# Split and capture the unique IDs of the panes
TOP_PANE=$(tmux display-message -p '#{pane_id}')
BOTTOM_PANE=$(tmux split-window -v -P -F '#{pane_id}')

# Small delay to let the shell initialize
sleep 0.5

# Get the TTY of the bottom pane
TTY=$(tmux display-message -t "$BOTTOM_PANE" -p "#{pane_tty}")

# Send the command to the TOP pane, redirecting stderr to the BOTTOM pane's TTY
# Added a 'clear' to make sure the prompt is visible
tmux send-keys -t "$TOP_PANE" "clear" C-m
tmux send-keys -t "$TOP_PANE" "$CMD 2> $TTY" C-m

# Attach
tmux attach-session -t binwalk_split

